# VMLedger Environment Configuration
# 
# This file contains all environment variables for VMLedger development.
# For production deployment, use .env.production.example as a template.
# 
# IMPORTANT: Never commit .env files with real credentials to version control!
# 
# For detailed documentation of all variables, see ENVIRONMENT_VARIABLES.md

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name displayed in logs and API responses
APP_NAME=VMLedger

# Application version (semantic versioning)
APP_VERSION=1.0.0

# Enable debug mode (MUST be False in production)
# When enabled: shows detailed errors, enables API docs at /api/docs
DEBUG=False

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Validates: Requirements 14.1-14.6
LOG_LEVEL=INFO

# ============================================================================
# API SETTINGS
# ============================================================================

# Host address for API server (0.0.0.0 = all interfaces)
API_HOST=0.0.0.0

# Port number for API server
API_PORT=8000

# Number of Gunicorn worker processes
# Recommendation: (2 * CPU_CORES) + 1
# Validates: Requirements 13.1-13.3
API_WORKERS=4

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# SECURITY: Change password in production!
# Validates: Requirements 13.4
DATABASE_URL=postgresql://vmledger:password@localhost:5432/vmledger

# Database connection pool size (minimum connections)
# Increase for high-traffic deployments
DATABASE_POOL_SIZE=5

# Maximum overflow connections beyond pool size
# Recommendation: 2-3x the pool size
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection URL for Celery and caching
# Format: redis://[host]:[port]/[db] or redis://:[password]@[host]:[port]/[db]
REDIS_URL=redis://localhost:6379/0

# Redis authentication password (recommended for production)
REDIS_PASSWORD=

# ============================================================================
# SECURITY SETTINGS (CRITICAL)
# ============================================================================

# Secret key for JWT token signing
# CRITICAL: Generate a secure random value for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit production values to version control!
# Validates: Requirements 10.1-10.4
SECRET_KEY=your-secret-key-here-change-in-production

# Master encryption key for AES-256 credential encryption
# CRITICAL: Generate a secure random value for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit production values to version control!
# Loss of this key means all stored credentials become unrecoverable!
# Validates: Requirements 2.1, 2.2
ENCRYPTION_MASTER_KEY=your-encryption-master-key-here-change-in-production

# JWT signing algorithm (HS256, HS384, HS512)
# Validates: Requirements 10.3
JWT_ALGORITHM=HS256

# JWT token expiration in hours
# Validates: Requirements 10.4
JWT_EXPIRATION_HOURS=24

# ============================================================================
# AUTHENTICATION SETTINGS
# ============================================================================

# Minimum password length for user registration
# Validates: Requirements 10.5
PASSWORD_MIN_LENGTH=12

# Maximum failed login attempts before account lockout
# Validates: Requirements 10.6
MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes after max failed attempts
# Validates: Requirements 10.6
ACCOUNT_LOCKOUT_MINUTES=30

# API rate limit per user per minute
# Validates: Requirements 13.1-13.3
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# MONITORING SETTINGS
# ============================================================================
# These settings control monitoring intervals and can be changed without restart

# Interval in seconds between Custom_Ping health checks
# Lower values = faster detection, higher system load
# Validates: Requirements 4.1, 15.1
PING_INTERVAL_SECONDS=60

# Interval in seconds between SSH metric collection
# Lower values = more granular data, more SSH connections
# Validates: Requirements 5.6, 15.2
METRICS_INTERVAL_SECONDS=300

# Cooldown period in minutes to prevent duplicate alerts
# Validates: Requirements 8.5, 15.3
ALERT_COOLDOWN_MINUTES=15

# Number of concurrent Celery worker processes
# Set based on number of VMs and available resources
# Validates: Requirements 9.1-9.5, 15.4
CONCURRENT_WORKERS=10

# ============================================================================
# SSH SETTINGS
# ============================================================================

# Timeout in seconds for establishing SSH connections
# Validates: Requirements 5.1-5.5
SSH_CONNECTION_TIMEOUT=10

# Timeout in seconds for executing SSH commands
# Validates: Requirements 5.1-5.5
SSH_COMMAND_TIMEOUT=30

# Maximum number of retry attempts for failed SSH connections
# Validates: Requirements 5.5
SSH_MAX_RETRIES=3

# Delay in seconds between SSH retry attempts
# Validates: Requirements 5.5
SSH_RETRY_DELAY=5

# ============================================================================
# DATA RETENTION
# ============================================================================

# Number of ping results to retain per VM (most recent kept)
# Validates: Requirements 4.6
PING_RESULTS_RETENTION=100

# Number of metric records to retain per VM (most recent kept)
# Validates: Requirements 5.7
METRICS_RETENTION=1000

# Number of days to retain alert history
# Validates: Requirements 8.1-8.7
ALERTS_RETENTION_DAYS=90

# ============================================================================
# LOGGING
# ============================================================================

# Path to application log file
# Validates: Requirements 14.1-14.6
LOG_FILE_PATH=logs/vmledger.log

# Maximum log file size in MB before rotation
# Validates: Requirements 14.5
LOG_MAX_SIZE_MB=100

# Number of days to retain rotated log files
# Validates: Requirements 14.6
LOG_RETENTION_DAYS=30

# Log output format: json (production) or text (development)
# Validates: Requirements 14.1-14.6
LOG_FORMAT=json

# ============================================================================
# EMAIL SETTINGS (OPTIONAL)
# ============================================================================
# Only required if using email-based alerts

# SMTP server hostname
# Validates: Requirements 8.3
SMTP_HOST=smtp.gmail.com

# SMTP server port (25=unencrypted, 587=TLS, 465=SSL)
# Validates: Requirements 8.3
SMTP_PORT=587

# SMTP authentication username
# Validates: Requirements 8.3
SMTP_USERNAME=

# SMTP authentication password
# SECURITY: Do not commit production values!
# Validates: Requirements 8.3
SMTP_PASSWORD=

# Email address used as sender for alerts
# Validates: Requirements 8.3
SMTP_FROM_EMAIL=noreply@vmledger.local

# Enable TLS encryption for SMTP (recommended)
# Validates: Requirements 8.3
SMTP_USE_TLS=True

# ============================================================================
# CORS SETTINGS
# ============================================================================

# Comma-separated list of allowed CORS origins
# SECURITY: Update with actual frontend domain(s) in production!
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials (cookies, auth headers) in CORS requests
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# DOCUMENTATION
# ============================================================================
# For detailed documentation of all environment variables, see:
# - ENVIRONMENT_VARIABLES.md (comprehensive documentation)
# - .env.production.example (production template)
# - vmledger/config.py (configuration module)

