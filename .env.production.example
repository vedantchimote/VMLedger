# VMLedger Production Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.production: cp .env.production.example .env.production
# 2. Replace ALL placeholder values with secure production values
# 3. Set file permissions: chmod 600 .env.production
# 4. NEVER commit .env.production to version control!
# 
# For detailed documentation, see ENVIRONMENT_VARIABLES.md

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

APP_NAME=VMLedger
APP_VERSION=1.0.0

# CRITICAL: Must be False in production!
DEBUG=False

# Production logging level (INFO recommended)
LOG_LEVEL=INFO

# ============================================================================
# API SETTINGS
# ============================================================================

API_HOST=0.0.0.0
API_PORT=8000

# Set based on CPU cores: (2 * CPU_CORES) + 1
# Example: 4-core server = 9 workers
API_WORKERS=4

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# CRITICAL: Replace with production database credentials!
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://vmledger:SecurePass123!@db.example.com:5432/vmledger_prod
DATABASE_URL=postgresql://vmledger:CHANGE_ME_STRONG_PASSWORD_HERE@db:5432/vmledger

# Production pool settings (increase for high traffic)
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=30

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Production Redis URL (use password authentication!)
# Format: redis://:[password]@[host]:[port]/[db]
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD_HERE@redis:6379/0

# CRITICAL: Set a strong Redis password!
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_HERE

# ============================================================================
# SECURITY SETTINGS (CRITICAL - MUST CHANGE!)
# ============================================================================

# CRITICAL: Generate secure random values!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# NEVER use default values in production!
# NEVER commit these values to version control!
# BACKUP these values securely - loss means data is unrecoverable!

# Secret key for JWT token signing
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_HERE

# Master encryption key for credential encryption
# WARNING: Loss of this key means all stored credentials become unrecoverable!
ENCRYPTION_MASTER_KEY=CHANGE_ME_GENERATE_STRONG_ENCRYPTION_KEY_HERE

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# AUTHENTICATION SETTINGS
# ============================================================================

# Strong password requirements for production
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# MONITORING SETTINGS
# ============================================================================
# Tune these based on your infrastructure size and requirements

# Ping interval: 60s = 1 check per minute per VM
PING_INTERVAL_SECONDS=60

# Metrics interval: 300s = 1 collection every 5 minutes per VM
METRICS_INTERVAL_SECONDS=300

# Alert cooldown: 15 minutes between duplicate alerts
ALERT_COOLDOWN_MINUTES=15

# Concurrent workers: Scale based on number of VMs
# 10 workers can handle ~50 VMs comfortably
# For 100+ VMs, increase to 20-30 workers
CONCURRENT_WORKERS=10

# ============================================================================
# SSH SETTINGS
# ============================================================================

SSH_CONNECTION_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30
SSH_MAX_RETRIES=3
SSH_RETRY_DELAY=5

# ============================================================================
# DATA RETENTION
# ============================================================================

# Adjust based on storage capacity and analysis needs
PING_RESULTS_RETENTION=100
METRICS_RETENTION=1000
ALERTS_RETENTION_DAYS=90

# ============================================================================
# LOGGING
# ============================================================================

LOG_FILE_PATH=logs/vmledger.log
LOG_MAX_SIZE_MB=100
LOG_RETENTION_DAYS=30

# Use JSON format for production (easier to parse and analyze)
LOG_FORMAT=json

# ============================================================================
# EMAIL SETTINGS (OPTIONAL)
# ============================================================================
# Configure if using email-based alerts

# SMTP server configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# CRITICAL: Set your SMTP credentials!
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password

# Sender email address for alerts
SMTP_FROM_EMAIL=noreply@vmledger.local

# Always use TLS in production
SMTP_USE_TLS=True

# ============================================================================
# CORS SETTINGS
# ============================================================================

# CRITICAL: Update with your actual frontend domain(s)!
# Remove localhost entries and add production URLs
# Example: https://vmledger.example.com,https://www.vmledger.example.com
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, verify:
# 
# [ ] Generated secure SECRET_KEY (32+ characters)
# [ ] Generated secure ENCRYPTION_MASTER_KEY (32+ characters)
# [ ] Backed up ENCRYPTION_MASTER_KEY securely
# [ ] Changed DATABASE_URL password from default
# [ ] Set REDIS_PASSWORD to secure value
# [ ] Set DEBUG=False
# [ ] Updated CORS_ORIGINS with production frontend URL(s)
# [ ] Configured SMTP settings if using email alerts
# [ ] Set appropriate DATABASE_POOL_SIZE for expected load
# [ ] Set appropriate CONCURRENT_WORKERS for number of VMs
# [ ] Set file permissions: chmod 600 .env.production
# [ ] Verified .env.production is in .gitignore
# [ ] Tested database connection
# [ ] Tested Redis connection
# [ ] Tested SMTP connection (if using email alerts)
# [ ] Reviewed all settings in ENVIRONMENT_VARIABLES.md
# 
# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# 
# 1. NEVER commit .env.production to version control
# 2. Use secrets management in production (AWS Secrets Manager, Vault, etc.)
# 3. Rotate credentials every 90 days
# 4. Enable TLS/SSL for all external connections
# 5. Use strong passwords (16+ characters, mixed case, numbers, symbols)
# 6. Backup ENCRYPTION_MASTER_KEY - loss means credential data is unrecoverable
# 7. Monitor logs for security events
# 8. Keep dependencies updated
# 9. Run security audits regularly
# 10. Restrict network access to database and Redis
# 
# ============================================================================
# DOCUMENTATION
# ============================================================================
# 
